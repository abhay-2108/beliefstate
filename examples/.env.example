# BeliefState Streamlit Demo - Environment Configuration Example
#
# Copy this file to .env and fill in your actual values
# IMPORTANT: Do NOT commit .env to Git (add to .gitignore)
#
# Get your free NVIDIA API Key at: https://build.nvidia.com/

# NVIDIA API Key (Required for Streamlit Demo)
# Get from: https://build.nvidia.com/ → Connect/Get API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Other LLM Provider Keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Database Configuration
# DB_PATH=./beliefs.db
# REDIS_URL=redis://localhost:6379

# Optional: Model Override
# NVIDIA_MODEL=nvidia/mixtral-8x7b-instruct-v0.1

# Notes:
# - Each line is: KEY=VALUE (no spaces around =)
# - Lines starting with # are comments
# - This file is loaded automatically by python-dotenv
# - Keep this file secure, never share your API keys
